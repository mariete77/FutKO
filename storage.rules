rules_version = '2';

// FutKO Storage Rules
// Bucket structure:
//   /badges/{teamId}.png — Team badges/crests
//   /stadiums/{stadiumId}.jpg — Stadium photos
//   /players/{playerId}.jpg — Player photos
//   /silhouettes/{playerId}.png — Player silhouettes for quiz
//   /competitions/{competitionId}.png — Competition logos
//   /questions/{questionId}/ — Custom question images

// Only authenticated users can read
// Only server/cloud functions can write
// Max file size: 5MB
// Allowed image types only

match /{allPaths=**} {
  allow read: if request.auth != null;
  allow write: if false; // Only through Firebase Admin SDK or Cloud Functions
  allow create: if false;
  allow delete: if false;
}

// Stricter rules for specific paths
match /silhouettes/{playerId} {
  allow read: if request.auth != null;
  allow write: if false;
  match /{fileName} {
    allow read: if request.auth != null;
    allow write: if false;
  }
}

match /badges/{teamId} {
  allow read: if request.auth != null;
  allow write: if false;
  match /{fileName} {
    allow read: if request.auth != null;
    allow write: if false;
  }
}
